# API Keys
GOOGLE_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Backend Database Config
DATABASE_URL=postgresql://postgres:postgres_password@db:5432/semantic_assistant_db
# For local running without docker-compose, use:
# DATABASE_URL=sqlite:///./local_db.sqlite

# Vector Store Directory
VECTOR_DB_DIR=./chroma_db
UPLOAD_DIR=./uploaded_papers

# Server Settings
BACKEND_PORT=8000
FRONTEND_PORT=8501
JWT_SECRET=super_secret_session_token_key_123!@#
RATE_LIMIT_PER_MINUTE=60
